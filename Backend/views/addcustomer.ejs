<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Add Customer</title>

    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.8/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.7.2/css/all.min.css">
    <link rel="stylesheet" href="/style.css">
</head>
<body class="dashboard-body">

<!-- Header Section -->
<div class="dashboard-header">
    <div class="container-fluid py-5">
        <div class="row align-items-center">
            <div class="col-md-8">
                <h1 class="dashboard-title mb-2">
                    <i class="fas fa-user-plus"></i> Add New Customer
                </h1>
                <p class="dashboard-subtitle">Create a new customer account for loan management</p>
            </div>
        </div>
    </div>
</div>

<!-- Main Content -->
<div class="container-fluid dashboard-container">
    <div class="row justify-content-center">
        <div class="col-lg-6 col-md-8 col-sm-10">
            <!-- Form Card -->
            <div class="dashboard-card form-card">
                <div class="card-body p-5">
                    <form action="/customer/new" method="POST" class="premium-form">

                        <!-- Customer Name Field -->
                        <div class="form-group mb-4">
                            <label class="form-label premium-label">
                                <i class="fas fa-user"></i> Customer Name
                            </label>
                            <div class="input-wrapper">
                                <input 
                                    type="text" 
                                    name="name" 
                                    class="form-control premium-input" 
                                    placeholder="Enter customer full name"
                                    required>
                                <span class="input-icon"><i class="fas fa-user"></i></span>
                            </div>
                            <small class="form-text">Full name of the customer</small>
                        </div>

                        <!-- Loan Amount Field -->
                        <div class="form-group mb-4">
                            <label class="form-label premium-label">
                                <i class="fas fa-money-bill"></i> Loan Amount (₹)
                            </label>
                            <div class="input-wrapper">
                                <input 
                                    type="number" 
                                    name="loan" 
                                    class="form-control premium-input" 
                                    placeholder="Enter loan amount"
                                    required>
                                <span class="input-icon"><i class="fas fa-rupee-sign"></i></span>
                            </div>
                            <small class="form-text">Initial loan amount in rupees</small>
                        </div>

                        <!-- Interest Rate Field -->
                        <div class="form-group mb-5">
                            <label class="form-label premium-label">
                                <i class="fas fa-percent"></i> Interest Rate (%)
                            </label>
                            <div class="input-wrapper">
                                <input 
                                    type="number" 
                                    name="interest" 
                                    class="form-control premium-input" 
                                    placeholder="Enter interest rate"
                                    required
                                    step="0.01">
                                <span class="input-icon"><i class="fas fa-percent"></i></span>
                            </div>
                            <small class="form-text">Interest rate percentage per annum</small>
                        </div>

                        <!-- Form Actions -->
                        <div class="form-actions">
                            <button type="submit" class="btn btn-submit">
                                <i class="fas fa-save"></i> Save Customer
                            </button>
                            <a href="/" class="btn btn-cancel">
                                <i class="fas fa-arrow-left"></i> Back to Dashboard
                            </a>
                        </div>

                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.8/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>