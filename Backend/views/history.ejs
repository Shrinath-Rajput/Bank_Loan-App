<!DOCTYPE html>
<html>
<head>
    <title>Customer History</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.8/dist/css/bootstrap.min.css" rel="stylesheet">
</head>
<body>

<div class="container mt-5">

    <h2 class="mb-4">Customer Loan Report</h2>

    <!-- Customer Details -->
    <div class="card p-3 mb-4">

        <h4><%= customer.Name %></h4>

        <div class="row">

            <div class="col-md-4">
                <p><b>Loan Amount :</b> ₹ <%= customer.Loan %></p>
            </div>

            <div class="col-md-4">
                <p><b>Interest Rate :</b> <%= customer.Interest %>%</p>
            </div>

            <div class="col-md-4">
                <p><b>Remaining Loan :</b> ₹ <%= customer.Remaining %></p>
            </div>

        </div>

    </div>

    <!-- Interest History -->

    <h4>Interest History</h4>

    <table class="table table-bordered table-hover">

        <thead class="table-dark">

            <tr>
                <th>Month</th>
                <th>Date</th>
                <th>Interest Amount</th>
            </tr>

        </thead>

        <tbody>

        <% let totalInterest = 0; %>

        <% history.forEach((h)=>{ %>

            <tr>

                <td>
                    <%= new Date(h.interest_date).toLocaleString('en-US',{month:'long'}) %>
                </td>

                <td>
                    <%= new Date(h.interest_date).toLocaleDateString() %>
                </td>

                <td>
                    ₹ <%= h.interest_amount %>
                </td>

            </tr>

            <% totalInterest += h.interest_amount; %>

        <% }) %>

        <tr class="table-success">

            <td colspan="2">
                <b>Total Interest</b>
            </td>

            <td>
                <b>₹ <%= totalInterest %></b>
            </td>

        </tr>

        </tbody>

    </table>

    <!-- Summary -->

    <div class="card p-3 mt-4">

        <h4>Summary</h4>

        <p>
            <b>Loan Amount :</b>
            ₹ <%= customer.Loan %>
        </p>

        <p>
            <b>Total Interest :</b>
            ₹ <%= totalInterest %>
        </p>

        <p>
            <b>Remaining Loan :</b>
            ₹ <%= customer.Remaining %>
        </p>

        <p>
            <b>Status :</b>

            <% if(customer.Remaining == 0){ %>
                Closed
            <% } else { %>
                Active
            <% } %>

        </p>

    </div>

    <br>

    <a href="/" class="btn btn-primary">
        Back Dashboard
    </a>

</div>

</body>
</html>