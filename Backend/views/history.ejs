<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Customer History</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.8/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.7.2/css/all.min.css">
    <link rel="stylesheet" href="/style.css">
</head>
<body class="dashboard-body">

<!-- Header Section -->
<div class="dashboard-header">
    <div class="container-fluid py-5">
        <div class="row align-items-center">
            <div class="col-md-8">
                <h1 class="dashboard-title mb-2">
                    <i class="fas fa-history"></i> Customer History & Report
                </h1>
                <p class="dashboard-subtitle">Comprehensive loan and transaction history</p>
            </div>
        </div>
    </div>
</div>

<!-- Main Content -->
<div class="container-fluid dashboard-container">
    <div class="row">
        <div class="col-12">
            
            <!-- Customer Details Card -->
            <div class="dashboard-card mb-4">
                <div class="card-body p-4">
                    <div class="row align-items-center mb-3">
                        <div class="col-md-8">
                            <h3 class="customer-title mb-0">
                                <i class="fas fa-user-circle"></i> <%= customer.Name %>
                            </h3>
                        </div>
                        <div class="col-md-4 text-md-end">
                            <% if(customer.Remaining == 0){ %>
                                <span class="status-badge status-closed">
                                    <i class="fas fa-check-circle"></i> Closed
                                </span>
                            <% } else { %>
                                <span class="status-badge status-active">
                                    <i class="fas fa-circle"></i> Active
                                </span>
                            <% } %>
                        </div>
                    </div>

                    <hr class="my-4">

                    <div class="row">
                        <div class="col-md-4 mb-3">
                            <div class="detail-box">
                                <span class="detail-icon"><i class="fas fa-money-bill"></i></span>
                                <div>
                                    <span class="detail-label">Loan Amount</span>
                                    <p class="detail-value">₹ <%= customer.Loan %></p>
                                </div>
                            </div>
                        </div>

                        <div class="col-md-4 mb-3">
                            <div class="detail-box">
                                <span class="detail-icon"><i class="fas fa-percent"></i></span>
                                <div>
                                    <span class="detail-label">Interest Rate</span>
                                    <p class="detail-value"><%= customer.Interest %>%</p>
                                </div>
                            </div>
                        </div>

                        <div class="col-md-4 mb-3">
                            <div class="detail-box">
                                <span class="detail-icon"><i class="fas fa-balance-scale"></i></span>
                                <div>
                                    <span class="detail-label">Remaining Loan</span>
                                    <p class="detail-value">₹ <%= customer.Remaining %></p>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Interest History Card -->
            <div class="dashboard-card mb-4">
                <div class="card-header bg-transparent border-bottom p-4">
                    <h5 class="mb-0">
                        <i class="fas fa-list"></i> Interest History
                    </h5>
                </div>
                
                <div class="table-responsive">
                    <table class="table table-hover dashboard-table mb-0">
                        <thead>
                            <tr>
                                <th><i class="fas fa-calendar"></i> Month</th>
                                <th><i class="fas fa-calendar-alt"></i> Date</th>
                                <th><i class="fas fa-money-bill-wave"></i> Interest Amount</th>
                            </tr>
                        </thead>
                        <tbody>
                            

                            <% if(history && history.length > 0){ %>
                                <% history.forEach((h)=>{ %>
                                    <tr class="table-row-hover">
                                        <td>
                                            <span class="history-month">
                                                <%= new Date(h.interest_date).toLocaleString('en-US',{month:'long'}) %>
                                            </span>
                                        </td>

                                        <td>
                                            <span class="history-date">
                                                <%= new Date(h.interest_date).toLocaleDateString() %>
                                            </span>
                                        </td>

                                        <td>
                                            <span class="amount-badge amount-primary">
                                                ₹ <%= h.interest_amount %>
                                            </span>
                                        </td>
                                    </tr>

                                    
                                <% }) %>

                                <tr class="history-total">
                                    <td colspan="2">
                                        <b><i class="fas fa-sum"></i> Total Interest</b>
                                    </td>

                                    <td>
                                        <span class="amount-badge amount-final">
                                            ₹ <%= history.reduce((sum, h) => sum + Number(h.interest_amount || 0), 0) %>
                                        </span>
                                    </td>
                                </tr>
                            <% } else { %>
                                <tr>
                                    <td colspan="3" class="text-center empty-state">
                                        <i class="fas fa-inbox"></i>
                                        <p>No interest records found</p>
                                    </td>
                                </tr>
                            <% } %>
                        </tbody>
                    </table>
                </div>
            </div>

            <!-- Summary Card -->
            <div class="dashboard-card mb-4">
                <div class="card-header bg-transparent border-bottom p-4">
                    <h5 class="mb-0">
                        <i class="fas fa-chart-pie"></i> Summary
                    </h5>
                </div>

                <div class="card-body p-4">
                    <div class="summary-grid">
                        <div class="summary-item">
                            <span class="summary-label">Loan Amount</span>
                            <p class="summary-value">₹ <%= customer.Loan %></p>
                        </div>

                        <div class="summary-item">
                            <span class="summary-label">Total Interest Charged</span>
                            <p class="summary-value">₹ 
                                
                                <%= history.reduce((sum, h) => sum + Number(h.interest_amount || 0), 0) %>
                            </p>
                        </div>

                        <div class="summary-item">
                            <span class="summary-label">Remaining Loan</span>
                            <p class="summary-value">₹ <%= customer.Remaining %></p>
                        </div>

                        <div class="summary-item">
                            <span class="summary-label">Status</span>
                            <p class="summary-value">
                                <% if(customer.Remaining == 0){ %>
                                    <span class="badge badge-status-closed">Closed</span>
                                <% } else { %>
                                    <span class="badge badge-status-active">Active</span>
                                <% } %>
                            </p>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Action Buttons -->
            <div class="mb-4">
                <a href="/" class="btn btn-back">
                    <i class="fas fa-arrow-left"></i> Back to Dashboard
                </a>
            </div>

        </div>
    </div>
</div>

<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.8/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>