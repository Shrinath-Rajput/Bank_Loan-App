<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Loan Management Dashboard</title>

    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.8/dist/css/bootstrap.min.css" rel="stylesheet">

    <link rel="stylesheet"
    href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.7.2/css/all.min.css">

    <link rel="stylesheet" href="/style.css">
</head>
<body class="dashboard-body">

<!-- Header Section -->
<div class="dashboard-header">
    <div class="container-fluid py-5">
        <div class="row align-items-center">
            <div class="col-md-8">
                <h1 class="dashboard-title mb-2">
                    <i class="fas fa-landmark"></i> Loan Management
                </h1>
                <p class="dashboard-subtitle">Track and manage your customer loans efficiently</p>
            </div>
            <div class="col-md-4 text-md-end text-start mt-3 mt-md-0">
                <a href="/add-customer" class="floating-btn">
                    <button class="btn btn-floating">
                        <i class="fas fa-plus"></i>
                    </button>
                    <span class="btn-tooltip">Add New Customer</span>
                </a>
            </div>
        </div>
    </div>
</div>

<!-- Main Content -->
<div class="container-fluid dashboard-container">
    <div class="row">
        <div class="col-12">
            <!-- Dashboard Card -->
             <div class="col-12">

    <!-- Summary Cards -->

    <div class="row mb-4">

        <div class="col-md-3">
            <div class="card shadow-lg border-0 text-center p-3">
                <h6>Total Given Amount</h6>
                <h3>₹ <%= totalGiven %></h3>
            </div>
        </div>

        <div class="col-md-3">
            <div class="card shadow-lg border-0 text-center p-3">
                <h6>Total Interest Received</h6>
                <h3>₹ <%= totalInterest %></h3>
            </div>
        </div>

        <div class="col-md-3">
            <div class="card shadow-lg border-0 text-center p-3">
                <h6>Total Received Amount</h6>
                <h3>₹ <%= totalReceived %></h3>
            </div>
        </div>

        <div class="col-md-3">
            <div class="card shadow-lg border-0 text-center p-3">
                <h6>Total Pending Amount</h6>
                <h3>₹ <%= totalPending %></h3>
            </div>
        </div>

    </div>

    <!-- Dashboard Card -->
    <div class="dashboard-card p-4">

    <h3 class="mb-4">
        <i class="fas fa-clock-rotate-left"></i>
        Recent Transactions
    </h3>

    <% if(loans && loans.length > 0){ %>

        <% loans.forEach((loan)=>{ %>

            <a href="/history/<%= loan.Name %>"
               class="list-group-item list-group-item-action p-4 mb-3 rounded shadow-sm">

                <h5>
                    <i class="fas fa-user-circle"></i>
                    <%= loan.Name %>
                </h5>

                <p class="mb-0">
                    Loan Amount :
                    <b>₹ <%= loan.Loan %></b>
                </p>

            </a>

        <% }) %>

    <% } %>

</div>

<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.8/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>