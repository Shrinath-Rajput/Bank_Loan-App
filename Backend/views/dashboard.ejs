<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Loan Management Dashboard</title>

    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.8/dist/css/bootstrap.min.css" rel="stylesheet">

    <link rel="stylesheet"
    href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.7.2/css/all.min.css">

    <link rel="stylesheet" href="/style.css">
</head>
<body class="dashboard-body">

<!-- Header Section -->
<div class="dashboard-header">
    <div class="container-fluid py-5">
        <div class="row align-items-center">
            <div class="col-md-8">
                <h1 class="dashboard-title mb-2">
                    <i class="fas fa-landmark"></i> Loan Management
                </h1>
                <p class="dashboard-subtitle">Track and manage your customer loans efficiently</p>
            </div>
            <div class="col-md-4 text-md-end text-start mt-3 mt-md-0">
                <a href="/add-customer" class="floating-btn">
                    <button class="btn btn-floating">
                        <i class="fas fa-plus"></i>
                    </button>
                    <span class="btn-tooltip">Add New Customer</span>
                </a>
            </div>
        </div>
    </div>
</div>

<!-- Main Content -->
<div class="container-fluid dashboard-container">
    <div class="row">
        <div class="col-12">

            <!-- Summary Cards -->
            <div class="row mb-5 g-3">

                <div class="col-md-3 col-sm-6">
                    <div class="stat-card stat-card-given">
                        <div class="stat-icon">
                            <i class="fas fa-money-bill-wave"></i>
                        </div>
                        <div class="stat-content">
                            <span class="stat-label">Total Given Amount</span>
                            <h3 class="stat-value">₹ <%= totalGiven %></h3>
                        </div>
                    </div>
                </div>

                <div class="col-md-3 col-sm-6">
                    <div class="stat-card stat-card-interest">
                        <div class="stat-icon">
                            <i class="fas fa-coins"></i>
                        </div>
                        <div class="stat-content">
                            <span class="stat-label">Total Interest Received</span>
                            <h3 class="stat-value">₹ <%= totalInterest %></h3>
                        </div>
                    </div>
                </div>

                <div class="col-md-3 col-sm-6">
                    <div class="stat-card stat-card-received">
                        <div class="stat-icon">
                            <i class="fas fa-arrow-rotate-left"></i>
                        </div>
                        <div class="stat-content">
                            <span class="stat-label">Total Received Amount</span>
                            <h3 class="stat-value">₹ <%= totalReceived %></h3>
                        </div>
                    </div>
                </div>

                <div class="col-md-3 col-sm-6">
                    <div class="stat-card stat-card-pending">
                        <div class="stat-icon">
                            <i class="fas fa-hourglass-end"></i>
                        </div>
                        <div class="stat-content">
                            <span class="stat-label">Total Pending Amount</span>
                            <h3 class="stat-value">₹ <%= totalPending %></h3>
                        </div>
                    </div>
                </div>

            </div>

            <!-- Recent Transactions Card -->
            <div class="dashboard-card recent-transactions-card">
                <div class="card-header-premium">
                    <h3 class="card-title-premium mb-0">
                        <i class="fas fa-clock-rotate-left"></i>
                        Recent Transactions
                    </h3>
                </div>

                <div class="transactions-container">
                    <% if(loans && loans.length > 0){ %>

                        <% loans.forEach((loan)=>{ %>

                            <a href="/history/<%= loan.Name %>"
                               class="transaction-card-item">

                                <div class="transaction-avatar">
                                    <i class="fas fa-user-circle"></i>
                                </div>

                                <div class="transaction-info">
                                    <h5 class="transaction-name">
                                        <%= loan.Name %>
                                    </h5>
                                    <p class="transaction-meta">
                                        Loan Amount
                                    </p>
                                </div>

                                <div class="transaction-amount">
                                    <span class="amount-highlight">₹ <%= loan.Loan %></span>
                                </div>

                            </a>

                        <% }) %>

                    <% } else { %>

                        <div class="empty-transactions">
                            <i class="fas fa-inbox"></i>
                            <p>No customers added yet</p>
                        </div>

                    <% } %>
                </div>

            </div>

        </div>
    </div>
</div>

<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.8/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>