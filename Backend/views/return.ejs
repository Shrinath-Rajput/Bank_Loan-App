<!DOCTYPE html>
<html>
<head>
    <title>Return Amount</title>

    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.8/dist/css/bootstrap.min.css" rel="stylesheet">
</head>
<body>

<div class="container mt-5">

    <h2>Return Amount</h2>

    <form action="/return/add" method="POST">

        <input
            type="hidden"
            name="customer_name"
            value="<%= name %>"
        >

        <div class="mb-3">

            <label>Return Amount</label>

            <input
                type="number"
                name="return_amount"
                class="form-control"
                required
            >

        </div>

        <div class="mb-3">

            <label>Date</label>

            <input
                type="date"
                name="return_date"
                class="form-control"
                required
            >

        </div>

        <button
            class="btn btn-success"
            type="submit"
        >
            Submit
        </button>

    </form>

</div>

</body>
</html>